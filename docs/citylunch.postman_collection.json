{
  "info": {
    "name": "CityLunch API",
    "description": "Collection complète pour l'API CityLunch (Produits, Livreurs, Auth, Sac).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "jwt_token", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{jwt_token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "Create product (PLAT)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Poulet rôti aux herbes\",\n  \"description\": \"Plat du jour\",\n  \"type\": \"PLAT\",\n  \"prix\": 12.5\n}"
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "Get product",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/products/1", "host": ["{{base_url}}"], "path": ["products", "1"] }
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"prix\": 13.0\n}" },
            "url": { "raw": "{{base_url}}/products/1", "host": ["{{base_url}}"], "path": ["products", "1"] }
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/products/1", "host": ["{{base_url}}"], "path": ["products", "1"] }
          }
        }
      ]
    },
    {
      "name": "Livreurs",
      "item": [
        {
          "name": "Create livreur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.email && data.mot_de_passe_initial) {",
                  "  pm.collectionVariables.set('livreur_email', data.email);",
                  "  pm.collectionVariables.set('livreur_password', data.mot_de_passe_initial);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jean.dupont@citylunch.fr\",\n  \"nom\": \"Dupont\",\n  \"prenom\": \"Jean\"\n}"
            },
            "url": { "raw": "{{base_url}}/livreurs", "host": ["{{base_url}}"], "path": ["livreurs"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (auto-store JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.access_token) pm.collectionVariables.set('jwt_token', data.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{livreur_email}}\",\n  \"password\": \"{{livreur_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Sac (JWT requis)",
      "item": [
        {
          "name": "Get my sac",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/sac", "host": ["{{base_url}}"], "path": ["sac"] }
          }
        },
        {
          "name": "Add product to sac",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"quantite\": 5\n}" },
            "url": { "raw": "{{base_url}}/sac/items", "host": ["{{base_url}}"], "path": ["sac", "items"] }
          }
        },
        {
          "name": "Remove product from sac",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"quantite\": 2\n}" },
            "url": { "raw": "{{base_url}}/sac/items", "host": ["{{base_url}}"], "path": ["sac", "items"] }
          }
        }
      ]
    }
  ]
}